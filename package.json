{
  "name": "teleprompt",
  "version": "0.1.0",
  "description": "Transparent screen-overlay teleprompter with voice pacing, cue points, and presentation drive",
  "main": "out/main/index.js",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Aaron Storey",
    "email": "astoreyai@users.noreply.github.com"
  },
  "homepage": "https://github.com/astoreyai/teleprompt",
  "repository": {
    "type": "git",
    "url": "https://github.com/astoreyai/teleprompt.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --linux",
    "package:appimage": "electron-vite build && electron-builder --linux AppImage",
    "package:deb": "electron-vite build && electron-builder --linux deb",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.1",
    "electron-store": "^10.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "dev.astoreyai.teleprompt",
    "productName": "Teleprompt",
    "copyright": "Copyright © 2026 Aaron Storey",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/.DS_Store"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/pdf-parse/**",
      "**/node_modules/mammoth/**"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] },
        { "target": "tar.gz", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "synopsis": "Transparent overlay teleprompter",
      "description": "Always-on-top transparent teleprompter with voice pacing, cue points, multi-format ingest (txt/md/rtf/docx/odt/pdf/html/fountain/srt/vtt), presentation drive, and configurable hotkeys.",
      "maintainer": "Aaron Storey <astoreyai@users.noreply.github.com>"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libxcb-dri3-0"
      ],
      "recommends": [
        "xdotool"
      ]
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "fileAssociations": [
      { "ext": "txt", "name": "Plain text", "mimeType": "text/plain", "role": "Viewer" },
      { "ext": "md", "name": "Markdown", "mimeType": "text/markdown", "role": "Viewer" },
      { "ext": "markdown", "name": "Markdown", "mimeType": "text/markdown", "role": "Viewer" },
      { "ext": "rtf", "name": "Rich Text", "mimeType": "application/rtf", "role": "Viewer" },
      { "ext": "docx", "name": "Word document", "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "role": "Viewer" },
      { "ext": "odt", "name": "OpenDocument Text", "mimeType": "application/vnd.oasis.opendocument.text", "role": "Viewer" },
      { "ext": "pdf", "name": "PDF", "mimeType": "application/pdf", "role": "Viewer" },
      { "ext": "html", "name": "HTML", "mimeType": "text/html", "role": "Viewer" },
      { "ext": "htm", "name": "HTML", "mimeType": "text/html", "role": "Viewer" },
      { "ext": "fountain", "name": "Fountain screenplay", "mimeType": "text/plain", "role": "Viewer" },
      { "ext": "srt", "name": "SubRip subtitles", "mimeType": "application/x-subrip", "role": "Viewer" },
      { "ext": "vtt", "name": "WebVTT subtitles", "mimeType": "text/vtt", "role": "Viewer" }
    ]
  }
}
